# --- Rust/Cargo ---
# Ignore the target directory which contains build artifacts
**/target/

# Ignore Cargo.lock files for all sub-projects (typical for learning/mono-repos)
**/Cargo.lock

# Backup files created by some rust tools
**/*.rs.bk

# --- IDEs and Editors ---
# JetBrains (IntelliJ, RustRover, etc.)
.idea/
*.iws
out/

# VS Code
.vscode/

# Vim/Emacs/Nano
[._]*.s[a-v][a-z]
[._]s[a-w][a-z]
*.un~
*~

# --- Operating Systems ---
.DS_Store
Thumbs.db

# --- Environment and Secrets ---
.env
.env.local
.env.*.local

# --- Debugging ---
**/*.pdb
